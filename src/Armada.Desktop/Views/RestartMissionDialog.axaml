<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Armada.Desktop.Views.RestartMissionDialog"
        Width="500" Height="380"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource SurfaceDarkBrush}"
        Title="Restart Mission">

    <Border Padding="24" Background="{DynamicResource SurfaceDarkBrush}"
            BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="1"
            CornerRadius="8">
        <StackPanel Spacing="12">
            <TextBlock Text="Restart Mission"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock Text="Modify the instructions before restarting, or leave as-is."
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />

            <TextBlock Text="Title" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
            <TextBox x:Name="TitleBox" FontSize="13" Padding="8,6"
                     Background="{DynamicResource SurfaceHoverBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource SurfaceBorderBrush}"
                     CornerRadius="6"
                     ToolTip.Tip="Mission title — edit before restarting if needed" />

            <TextBlock Text="Description" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
            <TextBox x:Name="DescriptionBox" FontSize="13" Padding="8,6"
                     Height="100" AcceptsReturn="True" TextWrapping="Wrap"
                     Background="{DynamicResource SurfaceHoverBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource SurfaceBorderBrush}"
                     CornerRadius="6"
                     VerticalContentAlignment="Top"
                     ToolTip.Tip="Mission instructions — edit before restarting if needed" />

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Cancel" Click="OnCancelClick"
                        Background="{DynamicResource SurfaceHoverBrush}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        CornerRadius="6" Padding="16,8" FontSize="13"
                        ToolTip.Tip="Cancel and return without restarting" />
                <Button Content="Restart Mission" Click="OnRestartClick"
                        Background="#1E90FF" Foreground="White"
                        CornerRadius="6" Padding="16,8" FontWeight="SemiBold" FontSize="13"
                        ToolTip.Tip="Restart this mission with the current title and description" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
