<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Armada.Desktop.ViewModels"
             x:Class="Armada.Desktop.Views.DispatchView"
             x:DataType="vm:DispatchViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="Dispatch" Classes="page-title" />
            <TextBlock Text="Send tasks to captains as individual missions or grouped voyages." Classes="page-subtitle" />

            <!-- Mode toggle -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Quick Dispatch" Classes="action"
                        Click="OnQuickModeClick" ToolTip.Tip="Send tasks as individual missions" />
                <Button Content="Voyage Builder" Classes="action"
                        Click="OnAdvancedModeClick" ToolTip.Tip="Create a named batch of missions" />
            </StackPanel>

            <!-- Quick Dispatch mode -->
            <Border Classes="card" x:Name="QuickPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="QUICK DISPATCH" Classes="section-header" Margin="0" />
                    <TextBlock Text="Enter a task or multiple tasks separated by semicolons."
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />

                    <!-- Vessel selector -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Target Vessel" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding Vessels}"
                                  SelectedValue="{Binding SelectedVesselId}"
                                  SelectedValueBinding="{Binding Id}"
                                  MinWidth="200" FontSize="13"
                                  ToolTip.Tip="Select the git repository to send tasks to">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Prompt -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Prompt" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding Prompt}" AcceptsReturn="True"
                                 MinHeight="80" MaxHeight="200"
                                 Watermark="Add rate limiting; Add request logging; Add input validation"
                                 FontSize="13"
                                 ToolTip.Tip="Enter tasks separated by semicolons — each becomes a separate mission" />
                    </StackPanel>

                    <!-- Parsed tasks preview -->
                    <Border Background="{DynamicResource SurfaceHoverBrush}" CornerRadius="4"
                            Padding="12,8" IsVisible="{Binding ParsedTasks.Count}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="PARSED TASKS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" />
                            <ItemsControl ItemsSource="{Binding ParsedTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource ArmadaBlueBrush}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding}" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Dispatch button -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Dispatch" Classes="action" Click="OnDispatchClick"
                                IsEnabled="{Binding !IsDispatching}" ToolTip.Tip="Send tasks to the selected vessel" />
                        <ProgressBar IsIndeterminate="True" Width="100" Height="3"
                                     IsVisible="{Binding IsDispatching}"
                                     Foreground="{StaticResource ArmadaBlueBrush}"
                                     VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{StaticResource StatusGreenBrush}"
                               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </Border>

            <!-- Advanced Voyage Builder -->
            <Border Classes="card" x:Name="AdvancedPanel" IsVisible="False">
                <StackPanel Spacing="12">
                    <TextBlock Text="VOYAGE BUILDER" Classes="section-header" Margin="0" />
                    <TextBlock Text="Create a named voyage with multiple missions."
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />

                    <!-- Vessel selector -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Target Vessel" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding Vessels}"
                                  SelectedValue="{Binding SelectedVesselId}"
                                  SelectedValueBinding="{Binding Id}"
                                  MinWidth="200" FontSize="13"
                                  ToolTip.Tip="Select the git repository for all missions in this voyage">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Voyage title -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Voyage Title" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding VoyageTitle}"
                                 Watermark="API Hardening" FontSize="13"
                                 ToolTip.Tip="A descriptive name for this batch of missions" />
                    </StackPanel>

                    <!-- Mission entries -->
                    <StackPanel Spacing="4">
                        <DockPanel>
                            <TextBlock Text="Missions" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" DockPanel.Dock="Left"
                                       VerticalAlignment="Center" />
                            <Button Content="+ Add Mission" Classes="action" HorizontalAlignment="Right"
                                    Click="OnAddMissionClick" Padding="8,4" FontSize="11"
                                    ToolTip.Tip="Add another mission to this voyage" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding MissionEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MissionEntry">
                                    <Border Background="{DynamicResource SurfaceHoverBrush}"
                                            CornerRadius="4" Padding="8" Margin="0,4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Spacing="4">
                                                <TextBox Text="{Binding Title}"
                                                         Watermark="Mission title" FontSize="12"
                                                         ToolTip.Tip="Short title describing the work for this mission" />
                                                <TextBox Text="{Binding Description}"
                                                         Watermark="Description (optional)" FontSize="11"
                                                         ToolTip.Tip="Detailed instructions for the AI agent (optional)" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="X" Classes="danger"
                                                    Margin="8,0,0,0" VerticalAlignment="Top"
                                                    Click="OnRemoveMissionClick" Padding="6,4" FontSize="10"
                                                    ToolTip.Tip="Remove this mission from the voyage" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Launch button -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Launch Voyage" Classes="action" Click="OnLaunchVoyageClick"
                                IsEnabled="{Binding !IsDispatching}" ToolTip.Tip="Create and dispatch the voyage" />
                        <ProgressBar IsIndeterminate="True" Width="100" Height="3"
                                     IsVisible="{Binding IsDispatching}"
                                     Foreground="{StaticResource ArmadaBlueBrush}"
                                     VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{StaticResource StatusGreenBrush}"
                               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
