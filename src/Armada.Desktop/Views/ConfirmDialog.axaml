<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Armada.Desktop.Views.ConfirmDialog"
        Width="400" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource SurfaceDarkBrush}"
        Title="Confirm">

    <Border Padding="24" Background="{DynamicResource SurfaceDarkBrush}"
            BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="1"
            CornerRadius="8">
        <StackPanel Spacing="16">
            <TextBlock x:Name="TitleText" Text="Confirm Action"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock x:Name="MessageText" Text="Are you sure?"
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Cancel" Click="OnCancelClick"
                        Background="{DynamicResource SurfaceHoverBrush}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        CornerRadius="6" Padding="16,8" FontSize="13"
                        ToolTip.Tip="Cancel this action" />
                <Button x:Name="ConfirmButton" Content="Confirm" Click="OnConfirmClick"
                        Background="{StaticResource StatusRedBrush}" Foreground="White"
                        CornerRadius="6" Padding="16,8" FontWeight="SemiBold" FontSize="13"
                        ToolTip.Tip="Proceed with this action" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
