<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:Armada.Desktop.Converters"
        xmlns:models="using:Armada.Core.Models"
        x:Class="Armada.Desktop.Views.EditCaptainDialog"
        Width="560" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource SurfaceDarkBrush}"
        Title="Edit Captain">

    <Window.Resources>
        <conv:MissionStatusColorConverter x:Key="MissionStatusColor" />
    </Window.Resources>

    <Border Padding="24" Background="{DynamicResource SurfaceDarkBrush}"
            BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="1"
            CornerRadius="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <TextBlock Text="Edit Captain"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />

                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Name" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox x:Name="NameInput" Watermark="Captain Name"
                                 ToolTip.Tip="Display name for this captain" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Runtime" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox x:Name="RuntimeInput" Width="200" HorizontalAlignment="Left"
                                  ToolTip.Tip="AI agent runtime (e.g., claude-code, codex)" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Parallelism" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumericUpDown x:Name="ParallelismInput" Minimum="1" Maximum="64" Increment="1"
                                           Width="120" HorizontalAlignment="Left" FormatString="0"
                                           ToolTip.Tip="Maximum number of missions this captain can work on simultaneously" />
                            <TextBlock Text="Minimum 1 (sequential)" FontSize="11"
                                       Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Cancel" Click="OnCancelClick"
                            Background="{DynamicResource SurfaceHoverBrush}"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            CornerRadius="6" Padding="16,8" FontSize="13"
                            ToolTip.Tip="Discard changes and close" />
                    <Button Content="Save" Click="OnSaveClick"
                            Background="#1E90FF" Foreground="White"
                            CornerRadius="6" Padding="16,8" FontWeight="SemiBold" FontSize="13"
                            ToolTip.Tip="Save changes to this captain" />
                </StackPanel>

                <!-- Recent Missions -->
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <TextBlock Text="RECENT MISSIONS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDimBrush}" />

                    <ItemsControl x:Name="MissionsListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Mission">
                                <Button Classes="nav-item" HorizontalContentAlignment="Stretch"
                                        Click="OnMissionRowClick" Tag="{Binding Id}"
                                        Padding="8,6" Margin="0,1"
                                        Background="{DynamicResource SurfaceHoverBrush}"
                                        CornerRadius="4">
                                    <Grid ColumnDefinitions="*,80,120">
                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="11"
                                                   Foreground="{Binding Status, Converter={StaticResource MissionStatusColor}}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding CreatedUtc, StringFormat='{}{0:MM-dd HH:mm}'}"
                                                   FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoMissionsText" Text="No missions yet" FontSize="12"
                               Foreground="{DynamicResource TextDimBrush}"
                               HorizontalAlignment="Center" Margin="0,4" IsVisible="False" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
