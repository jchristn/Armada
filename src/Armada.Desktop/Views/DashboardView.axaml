<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Armada.Desktop.ViewModels"
             x:Class="Armada.Desktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">

            <!-- Page header -->
            <DockPanel>
                <TextBlock Text="Dashboard" Classes="page-title" DockPanel.Dock="Left" />
                <TextBlock Text="{Binding LastRefresh}" FontSize="11"
                           Foreground="{DynamicResource TextDimBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           ToolTip.Tip="Time of last data refresh from the Admiral server" />
            </DockPanel>
            <TextBlock Text="Overview of captains, missions, voyages, and system alerts." Classes="page-subtitle" />

            <!-- Summary cards row -->
            <WrapPanel Orientation="Horizontal">
                <!-- Captain stats -->
                <Border Classes="stat-card">
                    <StackPanel Spacing="4">
                        <TextBlock Text="CAPTAINS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}" ToolTip.Tip="Total registered AI worker agents" />
                        <TextBlock Text="{Binding TotalCaptains}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,12,0"
                                        ToolTip.Tip="Captains waiting for work">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource ArmadaBlueBrush}" />
                                <TextBlock Text="{Binding IdleCaptains}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="idle" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,12,0"
                                        ToolTip.Tip="Captains currently executing missions">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StatusGreenBrush}" />
                                <TextBlock Text="{Binding WorkingCaptains}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="working" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"
                                        ToolTip.Tip="Captains that have stopped responding">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StatusRedBrush}" />
                                <TextBlock Text="{Binding StalledCaptains}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="stalled" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Mission stats -->
                <Border Classes="stat-card">
                    <StackPanel Spacing="4">
                        <TextBlock Text="MISSIONS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}" ToolTip.Tip="Currently active and queued missions" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel ToolTip.Tip="Missions currently being worked on by captains">
                                <TextBlock Text="{Binding InProgressMissions}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource StatusGoldBrush}" />
                                <TextBlock Text="active" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </StackPanel>
                            <StackPanel ToolTip.Tip="Missions waiting to be assigned to a captain">
                                <TextBlock Text="{Binding PendingMissions}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource TextDimBrush}" />
                                <TextBlock Text="queued" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="stat-card">
                    <StackPanel Spacing="4">
                        <TextBlock Text="RESULTS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}" ToolTip.Tip="Completed and failed mission outcomes" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel ToolTip.Tip="Missions that completed successfully">
                                <TextBlock Text="{Binding CompleteMissions}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource StatusGreenBrush}" />
                                <TextBlock Text="done" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </StackPanel>
                            <StackPanel ToolTip.Tip="Missions that encountered errors">
                                <TextBlock Text="{Binding FailedMissions}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource StatusRedBrush}" />
                                <TextBlock Text="failed" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="stat-card">
                    <StackPanel Spacing="4">
                        <TextBlock Text="VOYAGES" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}" ToolTip.Tip="Active mission batches" />
                        <TextBlock Text="{Binding ActiveVoyages}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource ArmadaBlueBrush}" />
                        <TextBlock Text="active" FontSize="10"
                                   Foreground="{DynamicResource TextDimBrush}" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Voyage progress -->
            <Border Classes="card" IsVisible="{Binding VoyageProgressItems.Count}">
                <StackPanel Spacing="8">
                    <TextBlock Text="VOYAGE PROGRESS" Classes="section-header" Margin="0"
                               ToolTip.Tip="Completion progress for active voyages" />
                    <ItemsControl ItemsSource="{Binding VoyageProgressItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:VoyageProgressItem">
                                <Border Margin="0,4" Padding="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="4">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
                                                <TextBlock Text="{Binding ProgressText}" FontSize="12"
                                                           Foreground="{StaticResource ArmadaBlueBrush}"
                                                           HorizontalAlignment="Right" Margin="8,0,0,0" />
                                            </DockPanel>
                                            <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100"
                                                         Height="4" Foreground="{StaticResource ArmadaBlueBrush}"
                                                         Background="{DynamicResource SurfaceBorderBrush}"
                                                         ToolTip.Tip="Percentage of missions completed in this voyage" />
                                            <TextBlock Text="{Binding FailedText}" FontSize="10"
                                                       Foreground="{StaticResource StatusRedBrush}"
                                                       IsVisible="{Binding FailedText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Delete" Classes="danger"
                                                Click="OnDeleteVoyageClick" Tag="{Binding VoyageId}"
                                                VerticalAlignment="Center" Margin="8,0,0,0"
                                                ToolTip.Tip="Permanently delete this voyage"
                                                IsVisible="{Binding CanDelete}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Two-column layout: Active Captains + Action Required -->
            <Grid ColumnDefinitions="*,*" Margin="0,0,0,0">

                <!-- Active Captains -->
                <Border Classes="card" Grid.Column="0" Margin="0,4,8,4">
                    <StackPanel Spacing="8">
                        <TextBlock Text="ACTIVE CAPTAINS" Classes="section-header" Margin="0"
                                   ToolTip.Tip="Captains currently working on or available for missions" />
                        <ItemsControl ItemsSource="{Binding ActiveCaptains}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CaptainItem">
                                    <Border Padding="8,6" Margin="0,2"
                                            Background="{DynamicResource SurfaceHoverBrush}"
                                            CornerRadius="4">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Ellipse Width="10" Height="10" Fill="{StaticResource ArmadaBlueBrush}"
                                                         ToolTip.Tip="Captain is online" />
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MissionTitle}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="Current mission being worked on" />
                                                <TextBlock Text="{Binding VesselName}" FontSize="10"
                                                           Foreground="{DynamicResource TextDimBrush}"
                                                           ToolTip.Tip="Repository this captain is working in" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding StateText}" FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       VerticalAlignment="Center"
                                                       ToolTip.Tip="Current captain state: Idle (waiting), Working (executing), or Stalled (unresponsive)" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No captains"
                                   FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                                   IsVisible="{Binding !ActiveCaptains.Count}"
                                   HorizontalAlignment="Center" Margin="0,8" />
                    </StackPanel>
                </Border>

                <!-- Action Required -->
                <Border Classes="card" Grid.Column="1" Margin="8,4,0,4">
                    <StackPanel Spacing="8">
                        <TextBlock Text="ACTION REQUIRED" Classes="section-header" Margin="0"
                                   Foreground="{StaticResource StatusGoldBrush}"
                                   ToolTip.Tip="Items that need your attention: failed missions, stalled captains, etc." />
                        <ItemsControl ItemsSource="{Binding ActionItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ActionItem">
                                    <Border Padding="8,6" Margin="0,2"
                                            Background="{DynamicResource SurfaceHoverBrush}"
                                            CornerRadius="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Classes="badge" Padding="6,2"
                                                            ToolTip.Tip="Alert severity level">
                                                        <TextBlock Text="{Binding Severity}" FontSize="10" FontWeight="Bold"
                                                                   Foreground="White" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Detail}" FontSize="10"
                                                           Foreground="{DynamicResource TextDimBrush}" Margin="4,0,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Delete" Classes="danger"
                                                    Click="OnDeleteMissionFromActionClick" Tag="{Binding MissionId}"
                                                    VerticalAlignment="Center" Margin="4,0,0,0"
                                                    IsVisible="{Binding MissionId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    ToolTip.Tip="Permanently delete this mission" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="All clear"
                                   FontSize="12" Foreground="{StaticResource StatusGreenBrush}"
                                   IsVisible="{Binding !ActionItems.Count}"
                                   HorizontalAlignment="Center" Margin="0,8" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Signals -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Text="RECENT SIGNALS" Classes="section-header" Margin="0"
                               ToolTip.Tip="Messages exchanged between the Admiral and captains" />
                    <ItemsControl ItemsSource="{Binding RecentSignals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SignalItem">
                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,2">
                                    <TextBlock Text="{Binding Timestamp}" FontSize="11" FontFamily="Cascadia Mono,Consolas,Courier New"
                                               Foreground="{DynamicResource TextDimBrush}" Width="60"
                                               ToolTip.Tip="Time the signal was sent" />
                                    <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource ArmadaBlueBrush}" Width="80"
                                               ToolTip.Tip="Signal type (e.g. progress, heartbeat, status)" />
                                    <TextBlock Text="{Binding From}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               ToolTip.Tip="Source of the signal" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No recent signals"
                               FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                               IsVisible="{Binding !RecentSignals.Count}"
                               HorizontalAlignment="Center" Margin="0,8" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
