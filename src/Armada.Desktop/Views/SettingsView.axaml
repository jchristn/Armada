<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Armada.Desktop.ViewModels"
             x:Class="Armada.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="Settings" Classes="page-title" />
            <TextBlock Text="Configure server connection, agent behavior, appearance, and integrations." Classes="page-subtitle" />

            <!-- Paths (read-only) -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="PATHS" Classes="section-header" Margin="0" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Data Directory" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                   ToolTip.Tip="Root directory for all Armada data" />
                        <TextBlock Text="{Binding DataDirectory}" FontSize="12" FontFamily="Consolas,monospace"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Database" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                   ToolTip.Tip="SQLite database file storing all Armada state" />
                        <TextBlock Text="{Binding DatabasePath}" FontSize="12" FontFamily="Consolas,monospace"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Logs" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                   ToolTip.Tip="Directory for Admiral and captain log files" />
                        <TextBlock Text="{Binding LogDirectory}" FontSize="12" FontFamily="Consolas,monospace"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Docks" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                   ToolTip.Tip="Directory for git worktrees used by captains" />
                        <TextBlock Text="{Binding DocksDirectory}" FontSize="12" FontFamily="Consolas,monospace"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Repos" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                   ToolTip.Tip="Directory for cloned git repositories" />
                        <TextBlock Text="{Binding ReposDirectory}" FontSize="12" FontFamily="Consolas,monospace"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Connection -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="CONNECTION" Classes="section-header" Margin="0" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Admiral Port" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <NumericUpDown Value="{Binding AdmiralPort}" Minimum="1" Maximum="65535"
                                       FormatString="0" FontSize="13"
                                       ToolTip.Tip="TCP port for the Admiral REST API" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="MCP Port" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <NumericUpDown Value="{Binding McpPort}" Minimum="1" Maximum="65535"
                                       FormatString="0" FontSize="13"
                                       ToolTip.Tip="TCP port for the MCP (Model Context Protocol) server" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Refresh Interval (seconds)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <NumericUpDown Value="{Binding RefreshInterval}" Minimum="1" Maximum="60"
                                       FormatString="0" FontSize="13"
                                       ToolTip.Tip="How often the desktop app polls the server for updates" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Agents & Timeouts -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="AGENTS" Classes="section-header" Margin="0" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Max Captains (0 = unlimited)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <NumericUpDown Value="{Binding MaxCaptains}" Minimum="0" Maximum="50"
                                       FormatString="0" FontSize="13"
                                       ToolTip.Tip="Maximum number of captains allowed (0 = no limit)" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Default Runtime" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding DefaultRuntime}" Watermark="auto-detect" FontSize="13"
                                 ToolTip.Tip="AI agent runtime used when none is specified (e.g., claude-code)" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Heartbeat Interval (seconds)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <NumericUpDown Value="{Binding HeartbeatIntervalSeconds}" Minimum="5" Maximum="300"
                                       FormatString="0" FontSize="13"
                                       ToolTip.Tip="How often captains send heartbeat signals to the Admiral" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Stall Threshold (minutes)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <NumericUpDown Value="{Binding StallThresholdMinutes}" Minimum="1" Maximum="60"
                                       FormatString="0" FontSize="13"
                                       ToolTip.Tip="Minutes without a heartbeat before a captain is marked as stalled" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Idle Captain Timeout (seconds, 0 = disabled)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <NumericUpDown Value="{Binding IdleCaptainTimeoutSeconds}" Minimum="0" Maximum="3600"
                                       FormatString="0" FontSize="13"
                                       ToolTip.Tip="Seconds before an idle captain is automatically stopped (0 = never)" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="API Key" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding ApiKey}" PasswordChar="*" Watermark="(not set)" FontSize="13"
                                 ToolTip.Tip="Authentication key for the Admiral API (leave blank for no auth)" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="APPEARANCE" Classes="section-header" Margin="0" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Theme:" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding ThemeModeOptions}"
                                  SelectedItem="{Binding ThemeMode}"
                                  MinWidth="140" FontSize="13"
                                  ToolTip.Tip="Choose between dark, light, or system-default theme" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Notifications -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="NOTIFICATIONS" Classes="section-header" Margin="0" />
                    <CheckBox Content="Desktop Notifications" IsChecked="{Binding Notifications}"
                              Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                              ToolTip.Tip="Show system notifications for mission completions, failures, and alerts" />
                    <CheckBox Content="Auto-Create Pull Requests" IsChecked="{Binding AutoCreatePr}"
                              Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                              ToolTip.Tip="Automatically create a pull request when a mission completes successfully" />
                </StackPanel>
            </Border>

            <!-- Server Control -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="SERVER" Classes="section-header" Margin="0" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Status:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ServerStatus}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource ArmadaBlueBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Check Status" Classes="action" Click="OnCheckServerClick" ToolTip.Tip="Check if the Admiral server is running" />
                        <Button Content="Stop Server" Classes="danger" Click="OnStopServerClick" ToolTip.Tip="Shut down the Admiral server" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- MCP Integration -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="MCP INTEGRATION" Classes="section-header" Margin="0" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="HTTP Config" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                        <TextBox Text="{Binding McpConfigHttp}" IsReadOnly="True"
                                 FontFamily="Consolas,monospace" FontSize="11"
                                 AcceptsReturn="True" Height="80"
                                 ToolTip.Tip="MCP configuration for HTTP transport — copy into your client's settings" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Stdio Config" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                        <TextBox Text="{Binding McpConfigStdio}" IsReadOnly="True"
                                 FontFamily="Consolas,monospace" FontSize="11"
                                 AcceptsReturn="True" Height="80"
                                 ToolTip.Tip="MCP configuration for stdio transport — copy into your client's settings" />
                    </StackPanel>
                    <Button Content="Install to Claude Code" Classes="action" Click="OnInstallMcpClick" ToolTip.Tip="Add Armada as an MCP server in Claude Code settings" />
                </StackPanel>
            </Border>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Save Settings" Classes="action" Click="OnSaveClick" ToolTip.Tip="Save all settings to disk" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{StaticResource StatusGreenBrush}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

            <!-- Danger Zone -->
            <Border BorderBrush="{StaticResource StatusRedBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16" Margin="0,16,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="DANGER ZONE" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource StatusRedBrush}" />
                    <TextBlock Text="Reset Armada to factory state. Deletes database, logs, docks, and repos. Settings file is preserved."
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <Button Content="Reset Armada" Classes="danger" Click="OnResetClick" ToolTip.Tip="Delete all data and reset to factory state" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
