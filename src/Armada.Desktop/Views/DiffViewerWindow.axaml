<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Armada.Desktop.ViewModels"
        xmlns:models="using:Armada.Desktop.Models"
        xmlns:conv="using:Armada.Desktop.Converters"
        x:Class="Armada.Desktop.Views.DiffViewerWindow"
        x:DataType="vm:DiffViewerViewModel"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceDarkBrush}"
        Icon="avares://Armada.Desktop/Assets/logo.png">

    <Window.Resources>
        <conv:DiffLineColorConverter x:Key="DiffLineColorConverter" />
        <conv:DiffLineBgConverter x:Key="DiffLineBgConverter" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceMidBrush}" Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center">
                    <Run Text="Diff: " />
                    <Run Text="{Binding MissionTitle}" Foreground="{StaticResource ArmadaBlueBrush}" />
                </TextBlock>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Copy Raw Diff" Classes="action" Click="OnCopyRawDiffClick"
                            ToolTip.Tip="Copy raw diff output to clipboard" />
                    <Button Content="Copy" Classes="action" Click="OnCopyAllClick"
                            ToolTip.Tip="Copy diff content to clipboard" />
                    <Button Content="Refresh" Classes="action" Click="OnRefreshClick"
                            ToolTip.Tip="Reload diff from server" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Panel Grid.Row="1">
            <!-- Loading -->
            <ProgressBar IsIndeterminate="True" Height="2" IsVisible="{Binding IsLoading}"
                         Foreground="{StaticResource ArmadaBlueBrush}" VerticalAlignment="Top" ZIndex="1" />

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}" FontSize="13"
                       Foreground="{DynamicResource TextDimBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Two-pane diff layout (when structured diff is available) -->
            <Grid ColumnDefinitions="250,1,*" IsVisible="{Binding HasParsedFiles}">

                <!-- Left pane: File navigator -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceMidBrush}">
                    <DockPanel>
                        <!-- File list header -->
                        <Border DockPanel.Dock="Top" Padding="12,8" BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource SurfaceBorderBrush}">
                            <TextBlock Text="FILES" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" />
                        </Border>

                        <!-- File list -->
                        <ListBox ItemsSource="{Binding ParsedFiles}"
                                 SelectedItem="{Binding SelectedFile}"
                                 Background="Transparent"
                                 Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:DiffFile">
                                    <Border Padding="8,6" CornerRadius="4">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding ShortFileName}" FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <DockPanel>
                                                <TextBlock Text="{Binding DirectoryPath}" FontSize="10"
                                                           Foreground="{DynamicResource TextDimBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           DockPanel.Dock="Left" />
                                                <StackPanel Orientation="Horizontal" Spacing="6"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding AdditionsText}" FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="#4CAF50" />
                                                    <TextBlock Text="{Binding DeletionsText}" FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="#EF5350" />
                                                </StackPanel>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Splitter -->
                <Border Grid.Column="1" Background="{DynamicResource SurfaceBorderBrush}" />

                <!-- Right pane: Diff content -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CurrentLines}" Margin="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DiffLine">
                                <Border Background="{Binding LineType, Converter={StaticResource DiffLineBgConverter}}"
                                        Padding="0" MinHeight="20">
                                    <Grid ColumnDefinitions="50,50,30,*">
                                        <!-- Old line number -->
                                        <Border Grid.Column="0" Padding="4,1,8,1"
                                                BorderThickness="0,0,1,0"
                                                BorderBrush="{DynamicResource SurfaceBorderBrush}">
                                            <TextBlock Text="{Binding OldLineNumber}"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- New line number -->
                                        <Border Grid.Column="1" Padding="4,1,8,1"
                                                BorderThickness="0,0,1,0"
                                                BorderBrush="{DynamicResource SurfaceBorderBrush}">
                                            <TextBlock Text="{Binding NewLineNumber}"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Prefix (+/-/space) -->
                                        <Border Grid.Column="2" Padding="8,1,4,1">
                                            <TextBlock Text="{Binding Prefix}"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       FontSize="12"
                                                       Foreground="{Binding LineType, Converter={StaticResource DiffLineColorConverter}}"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Content -->
                                        <Border Grid.Column="3" Padding="0,1,8,1">
                                            <TextBlock Text="{Binding Content}"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       FontSize="12"
                                                       Foreground="{Binding LineType, Converter={StaticResource DiffLineColorConverter}}"
                                                       TextWrapping="NoWrap"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Fallback: flat text display (when no structured diff) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8"
                          IsVisible="{Binding !HasParsedFiles}">
                <StackPanel Spacing="8">
                    <!-- JSON metadata section -->
                    <StackPanel Spacing="4"
                                IsVisible="{Binding DiffContent, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <DockPanel>
                            <TextBlock Text="RESPONSE" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <Button Content="Copy" FontSize="11" Padding="6,2" Click="OnCopyResponseClick"
                                        ToolTip.Tip="Copy JSON response to clipboard" />
                            </StackPanel>
                        </DockPanel>
                        <Border Background="{DynamicResource SurfaceMidBrush}" CornerRadius="4" Padding="8">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" MaxHeight="250">
                                <TextBlock Text="{Binding DiffContent}" FontFamily="Consolas,Courier New,monospace"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="NoWrap" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <!-- Expanded diff output section -->
                    <StackPanel Spacing="4" IsVisible="{Binding HasParsedDiff}">
                        <DockPanel>
                            <TextBlock Text="DIFF OUTPUT" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <Button Content="Copy" FontSize="11" Padding="6,2" Click="OnCopyDiffClick"
                                        ToolTip.Tip="Copy diff output to clipboard" />
                            </StackPanel>
                        </DockPanel>
                        <Border Background="{DynamicResource SurfaceMidBrush}" CornerRadius="4" Padding="8">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding ParsedDiffContent}" FontFamily="Consolas,Courier New,monospace"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="NoWrap" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Panel>
    </Grid>
</Window>
