<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Armada.Desktop.ViewModels"
             x:Class="Armada.Desktop.Views.DoctorView"
             x:DataType="vm:DoctorViewModel">

    <StackPanel Spacing="16">
        <DockPanel>
            <TextBlock Text="System Health" Classes="page-title" DockPanel.Dock="Left" />
            <Button Content="Re-run" Classes="action" HorizontalAlignment="Right"
                    Click="OnRerunClick" ToolTip.Tip="Run all diagnostic checks again" />
        </DockPanel>
        <TextBlock Text="Diagnostic checks for server connectivity, database, git, and agent runtimes." Classes="page-subtitle" />

        <ProgressBar IsIndeterminate="True" Height="2" IsVisible="{Binding IsRunning}"
                     Foreground="{StaticResource ArmadaBlueBrush}" />

        <Border Classes="card">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DoctorCheckResult">
                        <Border Padding="8,10" BorderBrush="{DynamicResource SurfaceBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="70,160,*">
                                <!-- Status badge -->
                                <Border Grid.Column="0" CornerRadius="4" Padding="8,2"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Background>
                                        <MultiBinding>
                                            <MultiBinding.Converter>
                                                <vm:DoctorStatusColorConverter />
                                            </MultiBinding.Converter>
                                            <Binding Path="Status" />
                                        </MultiBinding>
                                    </Border.Background>
                                    <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               ToolTip.Tip="Check result: PASS, WARN, or FAIL" />
                                </Border>

                                <!-- Check name -->
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />

                                <!-- Message -->
                                <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </StackPanel>
</UserControl>
