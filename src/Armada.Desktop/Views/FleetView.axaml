<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Armada.Desktop.ViewModels"
             xmlns:models="using:Armada.Core.Models"
             x:Class="Armada.Desktop.Views.FleetView"
             x:DataType="vm:FleetViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="Fleet Management" Classes="page-title" />
            <TextBlock Text="Manage fleet groupings, vessels (git repositories), and captains (AI agents)." Classes="page-subtitle" />

            <!-- Loading indicator -->
            <ProgressBar IsIndeterminate="True" Height="2" IsVisible="{Binding IsLoading}"
                         Foreground="{StaticResource ArmadaBlueBrush}" Margin="0,0,0,4" />

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                       Foreground="{StaticResource StatusRedBrush}" TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Tab selector -->
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                <Button Content="Fleets" Classes="action"
                        Click="OnTabClick" Tag="Fleets" ToolTip.Tip="Manage repository groupings" />
                <Button Content="Vessels" Classes="action"
                        Click="OnTabClick" Tag="Vessels" ToolTip.Tip="Manage git repositories" />
                <Button Content="Captains" Classes="action"
                        Click="OnTabClick" Tag="Captains" ToolTip.Tip="Manage AI worker agents" />
            </StackPanel>

            <!-- Fleets tab -->
            <Border Classes="card" IsVisible="{Binding SelectedTab, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    x:Name="FleetsPanel">
                <StackPanel Spacing="8">
                    <DockPanel>
                        <TextBlock Text="FLEETS" Classes="section-header" Margin="0" DockPanel.Dock="Left" />
                        <Button Content="Add Fleet" Classes="action"
                                HorizontalAlignment="Right" Click="OnToggleAddFleetClick" ToolTip.Tip="Create a new fleet grouping" />
                    </DockPanel>

                    <!-- Add Fleet form -->
                    <Border IsVisible="{Binding ShowAddFleet}" Background="{DynamicResource SurfaceHoverBrush}"
                            CornerRadius="6" Padding="12" Margin="0,4">
                        <StackPanel Spacing="8">
                            <TextBlock Text="NEW FLEET" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" />
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Watermark="Fleet Name" Text="{Binding NewFleetName}" Width="200" ToolTip.Tip="A short name for this fleet grouping" />
                                    <TextBox Watermark="Description (optional)" Text="{Binding NewFleetDescription}" Width="300" ToolTip.Tip="Optional description of the fleet's purpose" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Create" Classes="action" Click="OnAddFleetClick" ToolTip.Tip="Create the new fleet" />
                                    <Button Content="Cancel" Click="OnCancelAddFleetClick" ToolTip.Tip="Cancel fleet creation" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Column headers -->
                    <Grid ColumnDefinitions="150,*,70,200,150" Margin="8,0,8,4">
                        <TextBlock Grid.Column="0" Text="Name" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Display name for this fleet" />
                        <TextBlock Grid.Column="1" Text="Description" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Optional notes about this fleet" />
                        <TextBlock Grid.Column="2" Text="Active" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Whether this fleet is currently active" />
                        <TextBlock Grid.Column="3" Text="ID" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Unique fleet identifier (flt_ prefix)" />
                        <TextBlock Grid.Column="4" Text="Actions" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Edit or remove this fleet" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Fleets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FleetDisplayItem">
                                <Border Padding="8,6" Margin="0,2"
                                        Background="{DynamicResource SurfaceHoverBrush}"
                                        CornerRadius="4">
                                    <Grid ColumnDefinitions="150,*,70,200,150">
                                        <!-- Display mode -->
                                        <TextBlock Grid.Column="0" Text="{Binding Fleet.Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" IsVisible="{Binding !IsEditing}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Fleet.Description}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" TextAlignment="Left" IsVisible="{Binding !IsEditing}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Fleet.Active}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="3" Text="{Binding Fleet.Id}" FontSize="11"
                                                   Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" TextAlignment="Left" />
                                        <!-- Edit mode -->
                                        <TextBox Grid.Column="0" Text="{Binding EditName}" FontSize="12"
                                                 VerticalAlignment="Center" IsVisible="{Binding IsEditing}" />
                                        <TextBox Grid.Column="1" Text="{Binding EditDescription}" FontSize="12"
                                                 VerticalAlignment="Center" IsVisible="{Binding IsEditing}" />
                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <Button Content="Edit" Classes="action" FontSize="11" Padding="8,2"
                                                    Click="OnEditFleetClick" Tag="{Binding Fleet.Id}"
                                                    IsVisible="{Binding !IsEditing}" ToolTip.Tip="Edit name and description" />
                                            <Button Content="Save" Classes="action" FontSize="11" Padding="8,2"
                                                    Click="OnSaveFleetClick" Tag="{Binding Fleet.Id}"
                                                    IsVisible="{Binding IsEditing}" ToolTip.Tip="Save changes" />
                                            <Button Content="Cancel" FontSize="11" Padding="8,2"
                                                    Click="OnCancelEditFleetClick" Tag="{Binding Fleet.Id}"
                                                    IsVisible="{Binding IsEditing}" ToolTip.Tip="Discard changes" />
                                            <Button Content="Remove" Classes="danger" FontSize="11" Padding="8,2"
                                                    Click="OnRemoveFleetClick" Tag="{Binding Fleet.Id}" ToolTip.Tip="Permanently remove"
                                                    IsVisible="{Binding !IsEditing}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No fleets"
                               FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                               IsVisible="{Binding !Fleets.Count}"
                               HorizontalAlignment="Center" Margin="0,16" />
                </StackPanel>
            </Border>

            <!-- Vessels tab -->
            <Border Classes="card" x:Name="VesselsPanel" IsVisible="False">
                <StackPanel Spacing="8">
                    <DockPanel>
                        <TextBlock Text="VESSELS" Classes="section-header" Margin="0" DockPanel.Dock="Left" />
                        <Button Content="Add Vessel" Classes="action"
                                HorizontalAlignment="Right" Click="OnToggleAddVesselClick" ToolTip.Tip="Register a new git repository" />
                    </DockPanel>

                    <!-- Add Vessel form -->
                    <Border IsVisible="{Binding ShowAddVessel}" Background="{DynamicResource SurfaceHoverBrush}"
                            CornerRadius="6" Padding="12" Margin="0,4">
                        <StackPanel Spacing="8">
                            <TextBlock Text="NEW VESSEL" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" />
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Watermark="Name" Text="{Binding NewVesselName}" Width="200" ToolTip.Tip="A short name for this vessel" />
                                    <TextBox Watermark="Repo URL" Text="{Binding NewVesselRepoUrl}" Width="300" ToolTip.Tip="Git remote URL for cloning the repository (e.g., https://github.com/org/repo)" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Watermark="Branch (default: main)" Text="{Binding NewVesselBranch}" Width="200" ToolTip.Tip="Default branch name (e.g., main)" />
                                    <ComboBox PlaceholderText="Fleet (optional)"
                                              ItemsSource="{Binding Fleets}" SelectedValue="{Binding NewVesselFleetId}"
                                              SelectedValueBinding="{Binding Fleet.Id}" DisplayMemberBinding="{Binding Fleet.Name}" Width="200" ToolTip.Tip="Optionally assign this vessel to a fleet" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Create" Classes="action" Click="OnAddVesselClick" ToolTip.Tip="Register the new vessel" />
                                    <Button Content="Cancel" Click="OnCancelAddVesselClick" ToolTip.Tip="Cancel vessel creation" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Column headers -->
                    <Grid ColumnDefinitions="150,*,100,60,200,120" Margin="8,0,8,4">
                        <TextBlock Grid.Column="0" Text="Name" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Display name for this vessel" />
                        <TextBlock Grid.Column="1" Text="Repo URL" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Git remote URL for cloning" />
                        <TextBlock Grid.Column="2" Text="Branch" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Default branch for this repository" />
                        <TextBlock Grid.Column="3" Text="Config" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Configuration indicators (CTX=Project Context, STY=Style Guide)" />
                        <TextBlock Grid.Column="4" Text="ID" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Unique vessel identifier (vsl_ prefix)" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Vessels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Vessel">
                                <Border Padding="8,6" Margin="0,2"
                                        Background="{DynamicResource SurfaceHoverBrush}"
                                        CornerRadius="4">
                                    <Grid ColumnDefinitions="150,*,100,60,200,120">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="1" Text="{Binding RepoUrl}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" TextAlignment="Left" />
                                        <TextBlock Grid.Column="2" Text="{Binding DefaultBranch}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="CTX" FontSize="9" FontWeight="Bold" Foreground="#1E90FF"
                                                       IsVisible="{Binding ProjectContext, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       ToolTip.Tip="Has Project Context" />
                                            <TextBlock Text="STY" FontSize="9" FontWeight="Bold" Foreground="#1E90FF"
                                                       IsVisible="{Binding StyleGuide, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       ToolTip.Tip="Has Style Guide" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="4" Text="{Binding Id}" FontSize="11"
                                                   Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" TextAlignment="Left" />
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <Button Content="Edit" Classes="action" FontSize="11" Padding="8,2"
                                                    Click="OnEditVesselClick" Tag="{Binding Id}" ToolTip.Tip="Edit vessel settings" />
                                            <Button Content="Remove" Classes="danger" FontSize="11" Padding="8,2"
                                                    Click="OnRemoveVesselClick" Tag="{Binding Id}" ToolTip.Tip="Permanently remove" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No vessels registered"
                               FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                               IsVisible="{Binding !Vessels.Count}"
                               HorizontalAlignment="Center" Margin="0,16" />
                </StackPanel>
            </Border>

            <!-- Captains tab -->
            <Border Classes="card" x:Name="CaptainsPanel" IsVisible="False">
                <StackPanel Spacing="8">
                    <DockPanel>
                        <TextBlock Text="CAPTAINS" Classes="section-header" Margin="0" DockPanel.Dock="Left" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Content="Add Captain" Classes="action" Click="OnToggleAddCaptainClick" ToolTip.Tip="Create a new AI worker agent" />
                            <Button Content="Stop All" Classes="danger" Click="OnStopAllClick" ToolTip.Tip="Stop all working and stalled captains" />
                        </StackPanel>
                    </DockPanel>

                    <!-- Add Captain form -->
                    <Border IsVisible="{Binding ShowAddCaptain}" Background="{DynamicResource SurfaceHoverBrush}"
                            CornerRadius="6" Padding="12" Margin="0,4">
                        <StackPanel Spacing="8">
                            <TextBlock Text="NEW CAPTAIN" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Watermark="Captain Name" Text="{Binding NewCaptainName}" Width="200" ToolTip.Tip="A unique name for this captain" />
                                <ComboBox ItemsSource="{Binding RuntimeOptions}"
                                          SelectedItem="{Binding NewCaptainRuntime}" Width="160" ToolTip.Tip="AI agent runtime to use (e.g., claude-code)" />
                                <NumericUpDown Value="{Binding NewCaptainMaxParallelism}" Minimum="1" Maximum="64"
                                               Increment="1" Width="120" Watermark="Parallelism"
                                               ToolTip.Tip="Maximum concurrent missions (minimum 1)" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Create" Classes="action" Click="OnAddCaptainClick" ToolTip.Tip="Create the new captain" />
                                <Button Content="Cancel" Click="OnCancelAddCaptainClick" ToolTip.Tip="Cancel captain creation" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Column headers -->
                    <Grid ColumnDefinitions="140,100,70,80,200,60,150,Auto" Margin="8,0,8,4">
                        <TextBlock Grid.Column="0" Text="Name" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Captain display name" />
                        <TextBlock Grid.Column="1" Text="Runtime" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="AI agent runtime (e.g., claude-code, codex)" />
                        <TextBlock Grid.Column="2" Text="Parallel" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Maximum concurrent missions this captain can handle" />
                        <TextBlock Grid.Column="3" Text="State" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Current captain state: Idle (waiting), Working (executing), or Stalled (unresponsive)" />
                        <TextBlock Grid.Column="4" Text="Mission" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Currently assigned mission ID" />
                        <TextBlock Grid.Column="5" Text="PID" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Operating system process ID of the agent" />
                        <TextBlock Grid.Column="6" Text="Last Heartbeat" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" ToolTip.Tip="Last time this captain reported activity" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Captains}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Captain">
                                <Border Padding="8,6" Margin="0,2"
                                        Background="{DynamicResource SurfaceHoverBrush}"
                                        CornerRadius="4">
                                    <Grid ColumnDefinitions="140,100,70,80,200,60,150,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="1" Text="{Binding Runtime}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="2" Text="{Binding MaxParallelism}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="3" Text="{Binding State}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="4" Text="{Binding CurrentMissionId}" FontSize="11"
                                                   Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" TextAlignment="Left" />
                                        <TextBlock Grid.Column="5" Text="{Binding ProcessId}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="6" Text="{Binding LastHeartbeatUtc}" FontSize="11"
                                                   Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                            <Button Content="Edit" Classes="action" FontSize="11" Padding="8,2"
                                                    Click="OnEditCaptainClick" Tag="{Binding Id}" ToolTip.Tip="Edit captain settings" />
                                            <Button Content="Log" Classes="action" FontSize="11" Padding="8,2"
                                                    Click="OnViewLogClick" Tag="{Binding Id}" ToolTip.Tip="View captain output log" />
                                            <Button Content="Stop" Classes="action" FontSize="11" Padding="8,2"
                                                    Click="OnStopCaptainClick" Tag="{Binding Id}" ToolTip.Tip="Stop this captain" />
                                            <Button Content="Remove" Classes="danger" FontSize="11" Padding="8,2"
                                                    Click="OnRemoveCaptainClick" Tag="{Binding Id}" ToolTip.Tip="Permanently remove" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No captains"
                               FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                               IsVisible="{Binding !Captains.Count}"
                               HorizontalAlignment="Center" Margin="0,16" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
